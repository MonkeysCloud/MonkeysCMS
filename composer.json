{
  "name": "monkeyscloud/monkeyscms",
  "description": "A modern, code-first CMS built on MonkeysLegion v2 — visual page building, decoupled API, ML templates",
  "type": "project",
  "license": "MIT",
  "keywords": [
    "cms",
    "content-management",
    "monkeyslegion",
    "php",
    "framework",
    "page-builder",
    "api",
    "decoupled",
    "psr-7",
    "psr-15"
  ],
  "authors": [
    {
      "name": "Jorge Peraza",
      "email": "jorge@monkeys.cloud",
      "homepage": "https://monkeyslegion.com",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/MonkeysCloud/MonkeysCMS",
  "support": {
    "issues": "https://github.com/MonkeysCloud/MonkeysCMS/issues",
    "source": "https://github.com/MonkeysCloud/MonkeysCMS"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require": {
    "php": "^8.4",
    "monkeyscloud/monkeyslegion": "^2.0",
    "laminas/laminas-diactoros": "^3.8",
    "monolog/monolog": "^3.10",
    "monkeyscloud/monkeyslegion-cli": "^2.0.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "http-interop/http-factory-tests": "^2.2",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "process-timeout": 0,
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "post-create-project-cmd": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
      "@php vendor/bin/ml key:generate"
    ],
    "post-install-cmd": [
      "@php vendor/bin/ml key:generate --if-missing"
    ],
    "dev": "php -S localhost:8080 server.php",
    "serve": "php vendor/bin/dev-server",
    "server:start": "php vendor/bin/dev-server",
    "server:start:public": "php vendor/bin/dev-server 0.0.0.0 8000",
    "server:stop": "php vendor/bin/dev-server stop",
    "server:restart": "php vendor/bin/dev-server restart",
    "server:status": "php vendor/bin/dev-server status",
    "test": "phpunit",
    "test:unit": "phpunit --testsuite=Unit",
    "test:integration": "phpunit --testsuite=Integration",
    "test:feature": "phpunit --testsuite=Feature",
    "test:coverage": "phpunit --coverage-html coverage",
    "phpstan": "phpstan analyse app src tests --level=9",
    "cs": "phpcs --standard=PSR12 app src tests",
    "cs-fix": "phpcbf --standard=PSR12 app src tests",
    "check": [
      "@cs",
      "@phpstan",
      "@test"
    ]
  },
  "bin": [
    "bin/ml",
    "bin/dev-server",
    "bin/dev-router.php"
  ],
  "extra": {
    "branch-alias": {
      "dev-main": "2.0.x-dev"
    },
    "monkeyslegion": {
      "providers": [
        "App\\Cms\\Provider\\ContentProvider",
        "App\\Cms\\Provider\\MosaicProvider",
        "App\\Cms\\Provider\\MediaProvider",
        "App\\Cms\\Provider\\TaxonomyProvider",
        "App\\Cms\\Provider\\MenuProvider",
        "App\\Cms\\Provider\\UserProvider",
        "App\\Cms\\Provider\\ThemeProvider"
      ]
    }
  }
}
